# metrics.py - Helper functions for dashboard

import json
from pathlib import Path

def load_mock_data():
    """Load mock governance data from JSON file."""
    data_path = Path(__file__).parent / "data_mock.json"
    with open(data_path, "r", encoding="utf-8") as f:
        return json.load(f)

def get_status_color(status: str) -> str:
    """Return bootstrap-like color for status indicator."""
    colors = {
        "GREEN": "#28a745",
        "YELLOW": "#ffc107",
        "RED": "#dc3545"
    }
    return colors.get(status.upper(), "#6c757d")
```

### dashboard/app.py
```python
# app.py - Streamlit Transparency Dashboard Prototype

import streamlit as st
import pandas as pd
from metrics import load_mock_data, get_status_color

st.set_page_config(
    page_title="AnnabanAI Transparency Dashboard",
    page_icon="🛡️",
    layout="wide"
)

# Load mock data
data = load_mock_data()

# ── Header ───────────────────────────────────────────────
st.title("🛡️ AnnabanAI Transparency Dashboard")
st.caption("Conceptual AI Governance Framework – Human Sovereignty & Public Benefit")

# ── Governance Status Card ───────────────────────────────
status = data["governance_status"]
color = get_status_color(status)

st.subheader("Current Governance Status")
st.metric(
    label="Status",
    value=status,
    delta=None,
    delta_color="normal"
)

st.markdown(
    f"<div style='background-color:{color}; color:white; padding:12px; border-radius:6px; font-size:1.4rem; text-align:center; font-weight:bold;'>{status} – Last Audit: {data['last_audit']}</div>",
    unsafe_allow_html=True
)

st.markdown("---")

# ── Version History Table ────────────────────────────────
st.subheader("Revision History")

history_df = pd.DataFrame(data["revision_history"])
st.dataframe(
    history_df,
    column_config={
        "version": st.column_config.TextColumn("Version"),
        "date": st.column_config.DateColumn("Date"),
        "changes": st.column_config.TextColumn("Changes", width="large")
    },
    hide_index=True,
    use_container_width=True
)

# ── Contributors Panel ───────────────────────────────────
st.subheader("Community Contributors")

contributors_df = pd.DataFrame(data["contributors"])

st.dataframe(
    contributors_df,
    column_config={
        "name": "Name",
        "role": "Role",
        "contributions": st.column_config.NumberColumn("Contributions", format="%d")
    },
    hide_index=True,
    use_container_width=True
)

# ── Footer ───────────────────────────────────────────────
st.markdown("---")
st.caption("AnnabanAI v1.0.0 • Conceptual framework only • Sovereign Architect: Jacob Kinnaird • MIT License")
```

