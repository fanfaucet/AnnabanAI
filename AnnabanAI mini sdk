def human_approval(action_name: str, context: Dict[str, Any]) -> bool:
    """
    Example human override logic.
    Always approve safe, non-harmful actions.
    """
    if context.get("harm_risk", False):
        return False
    # Here you could add policies, whitelists, or interactive approval flows.
    return True


